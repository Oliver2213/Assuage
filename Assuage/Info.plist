<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSContactsUsageDescription</key>
	<string>Assuage reads the public keys and code-forge links saved on your contacts so you can encrypt to people by name, and verify signed notes from people you know. It adds a key to a contact only when you ask, and never deletes contacts.</string>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Age-encrypted file</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>org.age-encryption.age</string>
			</array>
		</dict>
		<dict>
			<!-- age identity files (.age-identity / .age-identities): opening one
			     brings the app forward with the Import Keys sheet loaded. -->
			<key>CFBundleTypeName</key>
			<string>Age identity file</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>dev.smoll.Assuage.age-identity</string>
				<string>dev.smoll.Assuage.age-identities</string>
			</array>
		</dict>
		<dict>
			<!-- Any file or folder, so dropping one on the Dock icon (or "Open
			     With") reaches application(_:open:), which encrypts it. Alternate
			     rank so we never become the default handler for other files. -->
			<key>CFBundleTypeName</key>
			<string>File or folder</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.data</string>
				<string>public.folder</string>
			</array>
		</dict>
	</array>
	<key>NSServices</key>
	<array>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Encrypt with Assuage</string>
			</dict>
			<key>NSMessage</key>
			<string>encryptService</string>
			<key>NSPortName</key>
			<string>Assuage</string>
			<key>NSSendTypes</key>
			<array>
				<string>public.utf8-plain-text</string>
				<string>public.file-url</string>
			</array>
		</dict>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Decrypt with Assuage</string>
			</dict>
			<key>NSMessage</key>
			<string>decryptService</string>
			<key>NSPortName</key>
			<string>Assuage</string>
			<key>NSSendTypes</key>
			<array>
				<string>public.utf8-plain-text</string>
				<string>public.file-url</string>
			</array>
		</dict>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Check if Assuage Can Decrypt</string>
			</dict>
			<key>NSMessage</key>
			<string>checkService</string>
			<key>NSPortName</key>
			<string>Assuage</string>
			<key>NSSendTypes</key>
			<array>
				<string>public.utf8-plain-text</string>
				<string>public.file-url</string>
			</array>
		</dict>
	</array>
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeDescription</key>
			<string>Age-encrypted file</string>
			<key>UTTypeIdentifier</key>
			<string>org.age-encryption.age</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>age</string>
				</array>
			</dict>
		</dict>
		<dict>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeDescription</key>
			<string>Age identity</string>
			<key>UTTypeIdentifier</key>
			<string>dev.smoll.Assuage.age-identity</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>age-identity</string>
				</array>
			</dict>
		</dict>
		<dict>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeDescription</key>
			<string>Age identities</string>
			<key>UTTypeIdentifier</key>
			<string>dev.smoll.Assuage.age-identities</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>age-identities</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
