<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)dev.smoll.Assuage</string>
	</array>
	<!-- Hardened Runtime → Address Book: lets this (non-sandboxed, hardened) app
	     request Contacts access. Without it, TCC denies the request without ever
	     prompting. This is NOT App Sandbox — the app stays unsandboxed. -->
	<key>com.apple.security.personal-information.addressbook</key>
	<true/>
</dict>
</plist>
